# Walletless approvals via zkLogin (Enoki). Optional — if either of these is
# unset, the app behaves exactly as without this feature: no zkLogin UI is
# rendered, and approvals/rejections are signed server-side as today.
#
# VITE_ENOKI_API_KEY=enoki_public_...
# VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# VITE_SUI_NETWORK=testnet
